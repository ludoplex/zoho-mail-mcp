# Zoho OAuth2 credentials — obtain from https://api-console.zoho.com/
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token

# Zoho data center (default: https://mail.zoho.com)
# Other options: https://mail.zoho.eu, https://mail.zoho.in, https://mail.zoho.com.au, https://mail.zoho.jp
ZOHO_MAIL_BASE_URL=https://mail.zoho.com

# Zoho accounts URL for OAuth token refresh (default: https://accounts.zoho.com)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Optional: pre-set account ID to skip auto-discovery
# ZOHO_ACCOUNT_ID=
